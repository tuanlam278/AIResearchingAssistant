# Google AI Studio — lấy tại https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
VISION_MODEL=gemini-3.1-flash-lite
# Cost guard: PDF Vision OCR fallback is disabled by default and only runs when explicitly enabled.
ENABLE_PDF_VISION_FALLBACK=false

# Optional local/advanced academic extraction toggles. pdfplumber table extraction is local and always attempted.
ENABLE_ADVANCED_TABLE_EXTRACTION=false

# Optional Math OCR; disabled by default. Do not fill paid keys unless intentionally enabling.
ENABLE_MATH_OCR=false
MATH_OCR_PROVIDER=none
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Groq — lấy tại https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_FLASHCARD_MODEL=llama-3.1-8b-instant

# Global Web Chat / Web Search provider (configure after implementing provider service)
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# Supabase — lấy tại Settings > API trong Supabase dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Dùng service_role, KHÔNG dùng anon
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# System Library admin upload account
# Development default can be admin/admin; change in production.
SYSTEM_LIBRARY_ADMIN_EMAIL=admin
SYSTEM_LIBRARY_ADMIN_PASSWORD=admin

# CORS — thêm URL của frontend vào đây
CORS_ORIGINS=["http://localhost:5173"]

# Supabase Storage buckets (private). Create them in Dashboard > Storage > Buckets.
NOTEBOOK_STORAGE_BUCKET=notebook-sources
INDEXING_STORAGE_BUCKET=notebook-sources
SYSTEM_LIBRARY_STORAGE_BUCKET=system-documents
COMMUNITY_LIBRARY_STORAGE_BUCKET=system-documents
AVATAR_STORAGE_BUCKET=avatars

# Upload/indexing limits
MAX_UPLOAD_MB=50
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_BATCH_SIZE=100
EMBEDDING_MAX_CONCURRENCY=3
# Smaller Supabase write batches reduce socket congestion during background indexing.
INDEX_INSERT_BATCH_SIZE=50
SUPABASE_VECTOR_INSERT_BATCH_SIZE=25
SUPABASE_REQUEST_TIMEOUT_SECONDS=240
SUPABASE_STORAGE_TIMEOUT_SECONDS=240
SUPABASE_FUNCTION_TIMEOUT_SECONDS=60
SUPABASE_RETRY_ATTEMPTS=4
SUPABASE_RETRY_BASE_DELAY_SECONDS=2

# RAG out-of-scope detection
RAG_RELEVANCE_THRESHOLD=0.35

# Google Identity Services OAuth client ID. Must match frontend VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# Required for backend self-verified Google login sessions. Generate a strong random value per environment; do not commit real secrets.
JWT_SECRET_KEY=


# Auth safety controls. Dev OTP 8888/default Google password 123456 only work when both are set as below.
APP_ENV=development
ENABLE_DEV_AUTH_BYPASS=false

# SMTP is required for real password reset / email 2FA emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

